{
  "name": "snaptrade-portfolio-backend",
  "version": "0.1.0",
  "imports": {
    "@orpc/server": "npm:@orpc/server@latest",
    "@orpc/openapi": "npm:@orpc/openapi@latest",
    "zod": "npm:zod@latest",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@latest"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --env main.ts",
    "gen:openapi": "deno run --allow-write --allow-read --allow-env scripts/gen_openapi.ts"
  }
}

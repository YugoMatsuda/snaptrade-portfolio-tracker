{
  "info": {
    "title": "SnapTrade Portfolio API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000/rpc"
    }
  ],
  "openapi": "3.1.1",
  "paths": {
    "/holdings/getAll": {
      "post": {
        "operationId": "holdings.getAll",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "positions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "symbol": {
                            "type": [
                              "object",
                              "null"
                            ],
                            "properties": {
                              "ticker": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              }
                            },
                            "required": [
                              "ticker",
                              "name"
                            ],
                            "additionalProperties": false
                          },
                          "units": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "price": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "open_pnl": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "average_purchase_price": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "symbol",
                          "units",
                          "price",
                          "open_pnl",
                          "average_purchase_price"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "balances": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "currency": {
                            "type": [
                              "object",
                              "null"
                            ],
                            "properties": {
                              "code": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "code"
                            ],
                            "additionalProperties": false
                          },
                          "cash": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "buying_power": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "currency",
                          "cash",
                          "buying_power"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "total_value": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "currency": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "required": [
                    "positions",
                    "balances",
                    "total_value",
                    "currency"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  }
}